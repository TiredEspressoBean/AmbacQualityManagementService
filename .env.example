# QMES Environment Configuration
# Copy this file to .env.docker and update the values
#
# Usage:
#   Local dev:  docker compose --profile local up -d
#   Production: docker compose --profile production up -d

# =============================================================================
# REQUIRED - Database
# =============================================================================
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=tracker_AMBAC
POSTGRES_USER=postgres

# =============================================================================
# REQUIRED - Redis
# =============================================================================
REDIS_PASSWORD=your-secure-redis-password

# =============================================================================
# REQUIRED - Django
# =============================================================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production

# Set to False for production
DJANGO_DEBUG=True

# Required when DJANGO_DEBUG=False. Used by django-encrypted-model-fields for
# column-level encryption. Must be a valid Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates all existing encrypted column values — treat it
# as permanent for the deployment.
FIELD_ENCRYPTION_KEY=generate-with-the-command-above

# =============================================================================
# REQUIRED - Initial Admin User (created on first run)
# =============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# =============================================================================
# PRODUCTION - Domain & TLS
# =============================================================================
# Caddy's hostname — the domain Caddy binds TLS to.
# Used for: Caddyfile {$SITE_DOMAIN} directive.
SITE_DOMAIN=localhost

# Django's domain allowlist. Comma-separated. Each entry is added to
# ALLOWED_HOSTS, CORS_ALLOWED_ORIGINS (with https:// prefix), and
# CSRF_TRUSTED_ORIGINS. Must match the hostname users actually browse to.
# For LAN deployments: set to your internal hostname (e.g. qmes.corp.local).
CUSTOM_DOMAINS=

# TLS cert/key — path inside the caddy container (./certs/ on host →
# /etc/caddy/certs/). Replace the filenames with whatever yours are actually
# named (e.g. govtracker.crt / govtracker.key).
TLS_CERT=/etc/caddy/certs/cert.crt
TLS_KEY=/etc/caddy/certs/cert.key

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# "dedicated" - Single tenant, simplified UX (recommended for on-prem)
# "saas"      - Multi-tenant with subdomain routing
DEPLOYMENT_MODE=dedicated

# For dedicated mode, set your organization name
DEFAULT_TENANT_NAME=My Company
DEFAULT_TENANT_SLUG=default

# --- SaaS mode only (ignored in dedicated mode) ---
# Base domain for subdomain tenant routing: "acme.uqmes.com" -> tenant "acme".
# Requires wildcard DNS + a *.<domain> custom domain on the proxy. Dedicated/
# on-prem deployments do NOT need this.
# TENANT_BASE_DOMAIN=uqmes.com
# Slugs that may never be claimed as a tenant (they become live subdomains).
# Comma-separated; overrides the built-in infra defaults. Infra names ONLY —
# never list a real tenant slug (e.g. "demo"), or its subdomain won't resolve.
# RESERVED_TENANT_SLUGS=www,api,app,admin,mail,docs

# =============================================================================
# SSO - Microsoft/Azure AD (Optional)
# =============================================================================
# Set SSO_ENABLED=false to use email/password only (no Microsoft button)
# SSO_ENABLED=true

# Azure App Registration credentials
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
# AZURE_TENANT_ID=common

# =============================================================================
# EMAIL (Optional)
# =============================================================================
# All email goes through Django's SMTP backend — works with SendGrid OR any
# on-prem relay by changing the values below. To disable sending entirely, set
# EMAIL_BACKEND to the console backend (prints to stdout) or dummy (discards):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Pick ONE of the blocks below.
#
# --- Option A: SendGrid (SMTP relay) -----------------------------------------
# Create an API key with "Mail Send" permission and verify your sender/domain.
# The username is the literal word "apikey"; the password is the API key.
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxx
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=QMES <noreply@your-verified-domain.com>
#
# --- Option B: On-prem / internal SMTP relay ---------------------------------
# Point at your internal relay. Many allow the app server's IP unauthenticated
# (leave USER/PASSWORD blank). Use 587 + EMAIL_USE_TLS for STARTTLS, or 465 +
# EMAIL_USE_SSL for implicit TLS, or 25 for unauthenticated Direct Send.
# EMAIL_HOST=smtp.corp.local
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# DEFAULT_FROM_EMAIL=QMES <noreply@your-company.com>
#
# Optional, applies to both: address for Django error/admin mail (defaults to
# DEFAULT_FROM_EMAIL), and outbound connect timeout in seconds.
# SERVER_EMAIL=qmes-alerts@your-company.com
# EMAIL_TIMEOUT=10

# =============================================================================
# BACKUP (Required for production)
# =============================================================================
# Generate with: openssl rand -base64 32
# Used by pgBackRest for encrypted database backups (AES-256-CBC)
BACKUP_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# Local path for media file backups (documents, 3D models)
# For NAS: mount your NAS here (e.g., /mnt/nas/qmes-backups)
# BACKUP_PATH=./backups

# Backup Commands:
#   Initialize (once):     docker compose exec postgres pgbackrest --stanza=tracker stanza-create
#   Full backup (weekly):  docker compose exec postgres pgbackrest --stanza=tracker backup --type=full
#   Diff backup (daily):   docker compose exec postgres pgbackrest --stanza=tracker backup --type=diff
#   Check status:          docker compose exec postgres pgbackrest --stanza=tracker info
#   Media files:           docker compose --profile backup run --rm media-backup
#   Full system backup:    docker compose --profile backup run --rm full-backup

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================
# HubSpot CRM integration
# HUBSPOT_API_KEY=your-hubspot-api-key

# LangSmith for AI tracing
# LANGSMITH_API_KEY=your-langsmith-api-key
