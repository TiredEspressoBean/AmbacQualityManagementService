# QMES Environment Configuration
# Copy this file to .env.docker and update the values
#
# Usage:
#   Local dev:  docker compose --profile local up -d
#   Production: docker compose --profile production up -d

# =============================================================================
# REQUIRED - Database
# =============================================================================
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=tracker_AMBAC
POSTGRES_USER=postgres

# =============================================================================
# REQUIRED - Redis
# =============================================================================
REDIS_PASSWORD=your-secure-redis-password

# =============================================================================
# REQUIRED - Django
# =============================================================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production

# Set to False for production
DJANGO_DEBUG=True

# =============================================================================
# REQUIRED - Initial Admin User (created on first run)
# =============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# =============================================================================
# PRODUCTION - Domain & TLS
# =============================================================================
# Your domain (e.g., qmes.acmecorp.com)
SITE_DOMAIN=localhost

# TLS certificate paths (place cert.crt and cert.key in ./certs/)
TLS_CERT=/etc/caddy/certs/cert.crt
TLS_KEY=/etc/caddy/certs/cert.key

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# "dedicated" - Single tenant, simplified UX (recommended for on-prem)
# "saas"      - Multi-tenant with subdomain routing
DEPLOYMENT_MODE=dedicated

# For dedicated mode, set your organization name
DEFAULT_TENANT_NAME=My Company
DEFAULT_TENANT_SLUG=default

# =============================================================================
# SSO - Microsoft/Azure AD (Optional)
# =============================================================================
# Set SSO_ENABLED=false to use email/password only (no Microsoft button)
# SSO_ENABLED=true

# Azure App Registration credentials
# AZURE_CLIENT_ID=your-app-client-id
# AZURE_CLIENT_SECRET=your-app-client-secret
# AZURE_TENANT_ID=common

# =============================================================================
# EMAIL (Optional)
# =============================================================================
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=QMES <noreply@example.com>

# =============================================================================
# BACKUP (Required for production)
# =============================================================================
# Generate with: openssl rand -base64 32
# Used by pgBackRest for encrypted database backups (AES-256-CBC)
BACKUP_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# Local path for media file backups (documents, 3D models)
# For NAS: mount your NAS here (e.g., /mnt/nas/qmes-backups)
# BACKUP_PATH=./backups

# Backup Commands:
#   Initialize (once):     docker compose exec postgres pgbackrest --stanza=tracker stanza-create
#   Full backup (weekly):  docker compose exec postgres pgbackrest --stanza=tracker backup --type=full
#   Diff backup (daily):   docker compose exec postgres pgbackrest --stanza=tracker backup --type=diff
#   Check status:          docker compose exec postgres pgbackrest --stanza=tracker info
#   Media files:           docker compose --profile backup run --rm media-backup
#   Full system backup:    docker compose --profile backup run --rm full-backup

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================
# HubSpot CRM integration
# HUBSPOT_API_KEY=your-hubspot-api-key

# LangSmith for AI tracing
# LANGSMITH_API_KEY=your-langsmith-api-key
