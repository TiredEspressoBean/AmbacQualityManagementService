# Railway Edge Proxy
# Routes all traffic to internal services via Railway private networking
#
# Environment variables (set in Railway):
#   BACKEND_URL  - e.g., backend.railway.internal:8000
#   FRONTEND_URL - e.g., frontend.railway.internal:8080
#   DOCS_URL     - e.g., docs.railway.internal:80

:{$PORT:80} {
    encode gzip

    # API routes to Django backend
    handle /api/* {
        reverse_proxy {$BACKEND_URL}
    }

    handle /auth/* {
        reverse_proxy {$BACKEND_URL}
    }

    handle /accounts/* {
        reverse_proxy {$BACKEND_URL}
    }

    handle /admin/* {
        reverse_proxy {$BACKEND_URL}
    }

    handle /media/* {
        reverse_proxy {$BACKEND_URL}
    }

    handle /static/* {
        reverse_proxy {$BACKEND_URL}
    }

    # Documentation (MkDocs)
    handle /docs/* {
        uri strip_prefix /docs
        reverse_proxy {$DOCS_URL}
    }

    # Frontend SPA (catch-all)
    handle {
        reverse_proxy {$FRONTEND_URL}
    }
}
