# Railway Edge Proxy
# Routes all traffic to internal services via Railway private networking
#
# Railway private DNS uses lowercase service names:
#   backend.railway.internal:8000
#   frontend.railway.internal:8080
#   docs.railway.internal:80

:{$PORT:80} {
    encode gzip

    # API routes to Django backend
    handle /api/* {
        reverse_proxy backend.railway.internal:8000
    }

    handle /auth/* {
        reverse_proxy backend.railway.internal:8000
    }

    handle /accounts/* {
        reverse_proxy backend.railway.internal:8000
    }

    handle /admin/* {
        reverse_proxy backend.railway.internal:8000
    }

    handle /media/* {
        reverse_proxy backend.railway.internal:8000
    }

    handle /static/* {
        reverse_proxy backend.railway.internal:8000
    }

    # Documentation (MkDocs)
    handle /docs/* {
        uri strip_prefix /docs
        reverse_proxy docs.railway.internal:80
    }

    # Frontend SPA (catch-all)
    handle {
        reverse_proxy frontend.railway.internal:8080
    }
}
