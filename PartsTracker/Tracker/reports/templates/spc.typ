// SPC Report template.
//
// Context: Tracker/reports/adapters/spc.py → SpcReportContext
//
// Layout:
//   1. Title block — measurement label + chart mode badge
//   2. Header grid (process / step / window / generator)
//   3. Specification limits
//   4. Active baseline (only when present)
//   5. Descriptive statistics
//   6. Process capability (Cp/Cpk/Pp/Ppk + interpretation)
//   7. Data points table (capped at 500 rows; flag when truncated)

#import "_common/page-setup.typ": *
#import "_common/components.typ": *

#let data = json.decode(sys.inputs.at("data"))

// ----------------------------------------------------------------------------
// Helpers — shared badge / field / divider come from _common/components.typ
// ----------------------------------------------------------------------------

#let mode-badge(m) = {
  if m == "xbar-r"      { badge("X̄-R", accent, rgb("#dbeafe")) }
  else if m == "xbar-s" { badge("X̄-S", accent, rgb("#dbeafe")) }
  else if m == "i-mr"   { badge("I-MR", accent, rgb("#dbeafe")) }
  else                  { badge(m,      muted,  rgb("#e2e8f0")) }
}

// Format optional numeric values (none → em-dash)
#let fmt-num(v, digits: 3, suffix: "") = {
  if v == none [ #text(fill: muted, style: "italic")[—] ]
  else [ #str(calc.round(v, digits: digits))#suffix ]
}

#let fmt-int(v) = if v == none [ #text(fill: muted, style: "italic")[—] ] else [ #str(v) ]

#let fmt-date(d) = if d == none or d == "" [ #text(fill: muted, style: "italic")[—] ] else [ #d ]

// ----------------------------------------------------------------------------
// Document
// ----------------------------------------------------------------------------

#show: page-setup.with(
  title: "SPC Report",
  doc-id: data.measurement_label,
  classification: "Controlled Document — Quality Management System",
)

// ── Title block ───────────────────────────────────────────────────────────────

#align(center)[
  #text(size: 9pt, fill: muted, tracking: 2pt, font: sans-font)[
    STATISTICAL PROCESS CONTROL REPORT
  ]
  #v(2pt)
  #text(size: 20pt, weight: "bold", font: sans-font)[#data.measurement_label]
  #v(-4pt)
  #text(size: 10pt, fill: muted)[#data.tenant_name]
  #v(6pt)
  #mode-badge(data.chart_mode)
]

#v(12pt)

// ── Header ───────────────────────────────────────────────────────────────────

= Header

#grid(
  columns: (1fr, 1fr),
  column-gutter: 16pt,
  row-gutter: 6pt,

  field("Process",     data.process_name),
  field("Step",        data.step_name),

  field("Window",      [#str(data.window_days) days]),
  field("Subgroup Size", str(data.subgroup_size)),

  field("Window Start", fmt-date(data.window_start)),
  field("Window End",   fmt-date(data.window_end)),

  field("Generated By", data.generated_by),
  field("Generated At", fmt-date(data.generated_at)),
)

#divider()

// ── Specification ────────────────────────────────────────────────────────────

= Specification

#grid(
  columns: (1fr, 1fr, 1fr),
  column-gutter: 16pt,
  row-gutter: 6pt,

  field("Nominal", fmt-num(data.spec.nominal, digits: 4, suffix: " " + data.spec.unit)),
  field("Upper Tol", fmt-num(data.spec.upper_tol, digits: 4)),
  field("Lower Tol", fmt-num(data.spec.lower_tol, digits: 4)),

  field("USL", fmt-num(data.spec.usl, digits: 4, suffix: " " + data.spec.unit)),
  field("LSL", fmt-num(data.spec.lsl, digits: 4, suffix: " " + data.spec.unit)),
  field("Unit", data.spec.unit),
)

#divider()

// ── Active Baseline ──────────────────────────────────────────────────────────

#if data.baseline != none [
  = Active Baseline

  #grid(
    columns: (1fr, 1fr),
    column-gutter: 16pt,
    row-gutter: 6pt,

    field("Chart Type",     data.baseline.chart_type),
    field("Subgroup Size",  str(data.baseline.subgroup_size)),

    field("Frozen By",      data.baseline.frozen_by),
    field("Frozen At",      fmt-date(data.baseline.frozen_at)),

    field("Sample Count",   str(data.baseline.sample_count)),
    field("Notes",          data.baseline.notes),
  )

  #v(6pt)
  #text(weight: "semibold", font: sans-font, size: 10pt)[Frozen Limits]
  #v(4pt)

  #table(
    columns: (1fr, 1fr, 1fr, 1fr),
    align: (left, right, right, right),
    stroke: 0.7pt + rule,
    inset: 6pt,
    table.header(
      [*Series*], [*UCL*], [*CL*], [*LCL*],
    ),
    [X̄],         fmt-num(data.baseline.xbar_ucl, digits: 4),
                 fmt-num(data.baseline.xbar_cl,  digits: 4),
                 fmt-num(data.baseline.xbar_lcl, digits: 4),
    [Range],     fmt-num(data.baseline.range_ucl, digits: 4),
                 fmt-num(data.baseline.range_cl,  digits: 4),
                 fmt-num(data.baseline.range_lcl, digits: 4),
    [Individual], fmt-num(data.baseline.individual_ucl, digits: 4),
                  fmt-num(data.baseline.individual_cl,  digits: 4),
                  fmt-num(data.baseline.individual_lcl, digits: 4),
    [MR],        fmt-num(data.baseline.mr_ucl, digits: 4),
                 fmt-num(data.baseline.mr_cl,  digits: 4),
                 [—],
  )

  #divider()
]

// ── Statistics ───────────────────────────────────────────────────────────────

= Descriptive Statistics

#grid(
  columns: (1fr, 1fr, 1fr, 1fr),
  column-gutter: 16pt,
  row-gutter: 6pt,

  field("Count",   fmt-int(data.statistics.count)),
  field("Mean",    fmt-num(data.statistics.mean,    digits: 4)),
  field("Std Dev", fmt-num(data.statistics.std_dev, digits: 4)),
  field("Range",   if data.statistics.min == none or data.statistics.max == none [
    #text(fill: muted, style: "italic")[—]
  ] else [
    #str(calc.round(data.statistics.min, digits: 4))#sym.dash.en
    #str(calc.round(data.statistics.max, digits: 4))
  ]),

  field("In Spec",     fmt-int(data.statistics.within_spec_count)),
  field("Out of Spec", fmt-int(data.statistics.out_of_spec_count)),
  field("", none),
  field("", none),
)

#divider()

// ── Capability ───────────────────────────────────────────────────────────────

= Process Capability

#grid(
  columns: (1fr, 1fr, 1fr, 1fr),
  column-gutter: 16pt,
  row-gutter: 6pt,

  field("Cp",  fmt-num(data.capability.cp,  digits: 3)),
  field("Cpk", fmt-num(data.capability.cpk, digits: 3)),
  field("Pp",  fmt-num(data.capability.pp,  digits: 3)),
  field("Ppk", fmt-num(data.capability.ppk, digits: 3)),

  field("σ within",  fmt-num(data.capability.std_dev_within,  digits: 4)),
  field("σ overall", fmt-num(data.capability.std_dev_overall, digits: 4)),
  field("Subgroups", fmt-int(data.capability.num_subgroups)),
  field("Sample",    fmt-int(data.capability.sample_size)),
)

#v(6pt)
#text(fill: muted, font: sans-font, size: 9pt)[*Interpretation*]
#v(2pt)
#if data.capability.interpretation == "" [
  #text(fill: muted, style: "italic")[—]
] else [
  #data.capability.interpretation
]

#divider()

// ── Data points ──────────────────────────────────────────────────────────────

= Measurements

#if data.data_points.len() == 0 [
  #text(fill: muted, style: "italic")[No data in window.]
] else [
  #if data.data_truncated [
    #v(2pt)
    #text(size: 9pt, fill: warn, font: sans-font)[
      Showing first #str(data.data_points.len()) of more than #str(data.data_points.len()) measurements.
    ]
    #v(4pt)
  ]

  #table(
    columns: (auto, 1fr, auto, auto, auto),
    align: (left, left, right, center, left),
    stroke: 0.7pt + rule,
    inset: 5pt,
    table.header(
      [*Timestamp*], [*Part*], [*Value*], [*Spec*], [*Operator*],
    ),
    ..for p in data.data_points {
      (
        text(size: 9pt)[#p.timestamp],
        text(size: 9pt)[#p.part_erp_id],
        text(size: 9pt, font: mono-font)[#str(calc.round(p.value, digits: 4))],
        if p.is_within_spec {
          text(size: 9pt, fill: ok)[OK]
        } else {
          text(size: 9pt, fill: bad, weight: "semibold")[OOS]
        },
        text(size: 9pt)[#if p.operator == none [—] else [#p.operator]],
      )
    }
  )
]
